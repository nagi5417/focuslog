generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon などのプール接続（pgbouncer）越しでは migrate が不安定なため
  // マイグレーションは unpooled（direct）接続を使う。
  // Neon が提供する変数名 DATABASE_URL_UNPOOLED にそのまま合わせている。
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------- 認証系（Auth.js v5 標準 + Credentials用の passwordHash）----------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  tasks       Task[]
  timeEntries TimeEntry[]
  projects    Project[]
  tags        Tag[]
  setting     Setting?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- アプリ系 ----------
model Task {
  id          String     @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]
  tagLinks    TaskTag[]

  @@index([userId, projectId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  taskId      String?
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model Setting {
  id     String @id @default(cuid())
  userId String @unique
  theme  String @default("system")
  accent String @default("blue")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskLinks TaskTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TaskTag {
  taskId    String
  tagId     String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
